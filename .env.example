# OKX DEX API (Web3) — https://www.okx.com/web3/build/docs/waas/introduction-to-developer-portal-interface
OKX_API_KEY=your_dex_api_key
OKX_SECRET_KEY=your_dex_secret_key
OKX_PASSPHRASE=your_dex_passphrase
OKX_PROJECT_ID=your_project_id

# OKX CEX API — https://www.okx.com/docs-v5/en/#overview
OKX_CEX_API_KEY=your_cex_api_key
OKX_CEX_SECRET_KEY=your_cex_secret_key
OKX_CEX_PASSPHRASE=your_cex_passphrase

# (Optional) EVM wallet for swap simulation
# EVM_WALLET_ADDRESS=0x...
